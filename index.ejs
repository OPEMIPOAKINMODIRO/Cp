
<!DOCTYPE html>
<html>
<head>
<title>Buycrpfropizca</title>
<style>
body { background:#0f0f0f; color:white; font-family:Arial; }
.card { background:#1a1a1a; padding:20px; margin:15px; border-radius:8px; }
button { padding:10px; background:#6a00ff; color:white; border:none; }
input { padding:10px; margin:5px; background:#222; color:white; border:1px solid #333; }
a { color:#6a00ff; }
</style>
</head>
<body>

<h1>Buycrpfropizca</h1>

<% if (!user) { %>
<form method="POST" action="/register">
<h3>Register</h3>
<input name="username" placeholder="Username" required>
<input type="password" name="password" placeholder="Password" required>
<button>Register</button>
</form>

<form method="POST" action="/login">
<h3>Login</h3>
<input name="username" placeholder="Username" required>
<input type="password" name="password" placeholder="Password" required>
<button>Login</button>
</form>
<% } else { %>
<p>Welcome <%= user.username %></p>
<% } %>

<h2>Courses</h2>
<% courses.forEach(course => { %>
<div class="card">
<h3><%= course.title %></h3>
<p>Price: $<%= course.price %></p>
<a href="/pay/<%= course.id %>"><button>Buy</button></a>
</div>
<% }) %>

<hr>
<p>Support: <a href="https://t.me/Sqyas6">Telegram</a></p>
<p>Email: am22yearsqueen@gmail.com</p>

</body>
</html>
